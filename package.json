{
  "name": "pg-backup-module",
  "version": "1.0.0",
  "description": "PostgreSQL backup scheduler with pg_dump, retention policy and per-database folders.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pg-backup-module": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "backup": "tsx src/index.ts --now",
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "postgresql",
    "postgres",
    "backup",
    "pg-dump",
    "database",
    "scheduler",
    "cron"
  ],
  "author": "GUILHERME DE OLIVEIRA",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}